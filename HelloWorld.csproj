using System;

namespace HelloWorld
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Hello, World!");
            PrintStudentInfo("Володимир Доценко", "ПЗПІ-25-3");
            Console.ReadLine();
        }

        // Метод, згенерований за допомогою ШІ для виведення даних студента
        static void PrintStudentInfo(string name, string group)
        {
            Console.WriteLine($"Студент: {name}");
            Console.WriteLine($"Група: {group}");
        }
    }
}
